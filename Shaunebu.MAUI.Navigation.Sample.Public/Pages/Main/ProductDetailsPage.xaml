<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Shaunebu.MAUI.Navigation.Sample.Public.Pages.Main.ProductDetailsPage"
             Title="Product Details">

    <ScrollView AutomationId="ProductDetailsPageRoot">
    <VerticalStackLayout Padding="24" Spacing="16" VerticalOptions="Center">

        <Label Text="📦 Product Details" FontSize="24" FontAttributes="Bold" />

        <!--
            Demonstrates: strongly typed parameter passing.
            ProductId and ProductName are injected via INavigationParameterReceiver<T>
            in ProductDetailsViewModel — no magic strings or query-params required.
        -->
        <Label Text="Product ID:" FontAttributes="Bold" />
        <Label AutomationId="ProductIdLabel" Text="{Binding ProductId}" FontSize="13" TextColor="Gray" />

        <Label Text="Product Name:" FontAttributes="Bold" />
        <Label AutomationId="ProductNameLabel" Text="{Binding ProductName}" FontSize="16" />

        <Button Text="← Back"
                AutomationId="BackButton"
                Command="{Binding GoBackCommand}"
                Style="{StaticResource SecondaryButton}" />

    </VerticalStackLayout>
    </ScrollView>

</ContentPage>
