<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Shaunebu.MAUI.Navigation.Sample.Public.Pages.Main.ProfilePage"
             Title="Profile">

    <ScrollView AutomationId="ProfilePageRoot">
    <VerticalStackLayout Padding="24" Spacing="16" VerticalOptions="Center">

        <Label Text="👤 Profile" FontSize="24" FontAttributes="Bold" />

        <!-- Demonstrates: typed navigation to EditProfilePage (unsaved-changes guard) -->
        <Button Text="Edit Profile"
                AutomationId="EditProfileButton"
                Command="{Binding GoToEditProfileCommand}" />

        <!-- Demonstrates: typed back navigation -->
        <Button Text="← Back"
                AutomationId="BackButton"
                Command="{Binding GoBackCommand}"
                Style="{StaticResource SecondaryButton}" />

    </VerticalStackLayout>
    </ScrollView>

</ContentPage>
